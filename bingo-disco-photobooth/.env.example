# --- Module photo IA Bingo Disco : configuration ---
# Copie ce fichier en .env (ou exporte ces variables dans ton shell).

# Clé API Google Gemini (https://aistudio.google.com/apikey).
# Si absente, le module tourne en MODE DEMO (aucun appel réseau, image factice).
GEMINI_API_KEY=

# Modèle d'édition/génération d'image. Du moins cher au plus qualitatif :
#   gemini-2.5-flash-image     → "Nano Banana"     ~0,039 $/img, 1K  (rapide, conservateur)
#   gemini-3.1-flash-image     → "Nano Banana 2"   ~0,067 $/img, jusqu'à 4K (bon compromis)
#   gemini-3-pro-image         → "Nano Banana Pro" ~0,134 $/img, jusqu'à 4K (qualité max, proche de l'app Gemini)
GEMINI_MODEL=gemini-2.5-flash-image

# Résolution de sortie : 1K / 2K / 4K (2K conseillé pour l'impression DNP).
# Laisser vide = résolution par défaut du modèle. (2K/4K : modèles Pro / Nano Banana 2.)
GEMINI_IMAGE_SIZE=
# Format de sortie : 1:1 (carré, conseillé écran+tirage), 3:4, 4:3, 9:16, 16:9…
GEMINI_ASPECT_RATIO=

# Code opérateur pour accéder à la console (/console).
OPERATOR_PIN=2468

# Hôte / port du serveur local.
HOST=0.0.0.0
PORT=5055

# Impression DNP DS620 (optionnel).
# Nom de la file d'impression CUPS (macOS : voir `lpstat -p`). Vide = impression désactivée.
DNP_PRINTER=
# Format papier DNP (ex. 4x6 / 5x7). Indicatif, transmis à lp si défini.
DNP_MEDIA=

# Dossier "hot folder" DNP (alternative à CUPS : on dépose le JPEG dedans). Vide = désactivé.
DNP_HOTFOLDER=
