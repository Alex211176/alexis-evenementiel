# --- Module photo IA Bingo Disco : configuration ---
# Copie ce fichier en .env (ou exporte ces variables dans ton shell).

# Clé API Google Gemini (https://aistudio.google.com/apikey).
# Si absente, le module tourne en MODE DEMO (aucun appel réseau, image factice).
GEMINI_API_KEY=

# Modèle d'édition/génération d'image (Gemini "Nano Banana").
GEMINI_MODEL=gemini-2.5-flash-image

# Code opérateur pour accéder à la console (/console).
OPERATOR_PIN=2468

# Hôte / port du serveur local.
HOST=0.0.0.0
PORT=5055

# Impression DNP DS620 (optionnel).
# Nom de la file d'impression CUPS (macOS : voir `lpstat -p`). Vide = impression désactivée.
DNP_PRINTER=
# Format papier DNP (ex. 4x6 / 5x7). Indicatif, transmis à lp si défini.
DNP_MEDIA=

# Dossier "hot folder" DNP (alternative à CUPS : on dépose le JPEG dedans). Vide = désactivé.
DNP_HOTFOLDER=
